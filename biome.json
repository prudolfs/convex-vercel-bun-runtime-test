{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/*.ts",
			"**/*.tsx",
			"**/*.js",
			"**/*.jsx",
			"**/*.json",
			"**/*.css",
			"!**/_generated",
			"!**/node_modules",
			"!**/dist",
			"!**/.convex"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"complexity": {
				"noUselessTypeConstraint": "error",
				"noUselessFragments": "error"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"useExhaustiveDependencies": "warn",
				"useHookAtTopLevel": "error"
			},
			"style": {
				"useConst": "error",
				"useSelfClosingElements": "error",
				"useTemplate": "error",
				"noNonNullAssertion": "warn",
				"useImportType": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": [
									"@/modules/*/internal",
									"@/modules/*/internal/**",
									"@/modules/*/ui",
									"@/modules/*/ui/**",
									"@/modules/*/model",
									"@/modules/*/model/**",
									"@/modules/*/hooks",
									"@/modules/*/hooks/**"
								],
								"message": "Cross-module imports must go through @/modules/<name> (index.ts). Reaching past the public API is forbidden."
							}
						]
					}
				}
			},
			"nursery": {
				"useSortedClasses": "error"
			},
			"suspicious": {
				"noVar": "error",
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn",
				"noConsole": { "level": "warn", "options": { "allow": ["warn", "error"] } },
				"noDoubleEquals": "error"
			}
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
